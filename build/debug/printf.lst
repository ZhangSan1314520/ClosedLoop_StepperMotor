  24:Lib/serial/printf.c **** //
  25:Lib/serial/printf.c **** // \brief Tiny printf, sprintf and (v)snprintf implementation, optimized for speed on
  26:Lib/serial/printf.c **** //        embedded systems with a very limited resources. These routines are thread
  27:Lib/serial/printf.c **** //        safe and reentrant!
  28:Lib/serial/printf.c **** //        Use this instead of the bloated standard/newlib printf cause these use
  29:Lib/serial/printf.c **** //        malloc for printf (and may not be thread safe).
  30:Lib/serial/printf.c **** //
  31:Lib/serial/printf.c **** ///////////////////////////////////////////////////////////////////////////////
  32:Lib/serial/printf.c **** 
ARM GAS  /tmp/cc7RggvS.s 			page 2


  33:Lib/serial/printf.c **** #include <stdbool.h>
  34:Lib/serial/printf.c **** #include <stdint.h>
  35:Lib/serial/printf.c **** 
  36:Lib/serial/printf.c **** #include "printf.h"
  37:Lib/serial/printf.c **** 
  38:Lib/serial/printf.c **** 
  39:Lib/serial/printf.c **** // define this globally (e.g. gcc -DPRINTF_INCLUDE_CONFIG_H ...) to include the
  40:Lib/serial/printf.c **** // printf_config.h header file
