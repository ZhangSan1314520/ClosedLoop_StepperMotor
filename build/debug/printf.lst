  45:Lib/serial/printf.c **** 
  46:Lib/serial/printf.c **** 
  47:Lib/serial/printf.c **** // 'ntoa' conversion buffer size, this must be big enough to hold one converted
  48:Lib/serial/printf.c **** // numeric number including padded zeros (dynamically created on stack)
  49:Lib/serial/printf.c **** // default: 32 byte
  50:Lib/serial/printf.c **** #ifndef PRINTF_NTOA_BUFFER_SIZE
  51:Lib/serial/printf.c **** #define PRINTF_NTOA_BUFFER_SIZE    32U
  52:Lib/serial/printf.c **** #endif
  53:Lib/serial/printf.c **** 
  54:Lib/serial/printf.c **** // 'ftoa' conversion buffer size, this must be big enough to hold one converted
  55:Lib/serial/printf.c **** // float number including padded zeros (dynamically created on stack)
  56:Lib/serial/printf.c **** // default: 32 byte
  57:Lib/serial/printf.c **** #ifndef PRINTF_FTOA_BUFFER_SIZE
  58:Lib/serial/printf.c **** #define PRINTF_FTOA_BUFFER_SIZE    32U
  59:Lib/serial/printf.c **** #endif
  60:Lib/serial/printf.c **** 
  61:Lib/serial/printf.c **** // support for the floating point type (%f)
  62:Lib/serial/printf.c **** // default: activated
  63:Lib/serial/printf.c **** #ifndef PRINTF_DISABLE_SUPPORT_FLOAT
  64:Lib/serial/printf.c **** #define PRINTF_SUPPORT_FLOAT
  65:Lib/serial/printf.c **** #endif
  66:Lib/serial/printf.c **** 
  67:Lib/serial/printf.c **** // support for exponential floating point notation (%e/%g)
  68:Lib/serial/printf.c **** // default: activated
  69:Lib/serial/printf.c **** #ifndef PRINTF_DISABLE_SUPPORT_EXPONENTIAL
  70:Lib/serial/printf.c **** #define PRINTF_SUPPORT_EXPONENTIAL
  71:Lib/serial/printf.c **** #endif
  72:Lib/serial/printf.c **** 
  73:Lib/serial/printf.c **** // define the default floating point precision
  74:Lib/serial/printf.c **** // default: 6 digits
  75:Lib/serial/printf.c **** #ifndef PRINTF_DEFAULT_FLOAT_PRECISION
  76:Lib/serial/printf.c **** #define PRINTF_DEFAULT_FLOAT_PRECISION  6U
  77:Lib/serial/printf.c **** #endif
  78:Lib/serial/printf.c **** 
  79:Lib/serial/printf.c **** // define the largest float suitable to print with %f
  80:Lib/serial/printf.c **** // default: 1e9
  81:Lib/serial/printf.c **** #ifndef PRINTF_MAX_FLOAT
  82:Lib/serial/printf.c **** #define PRINTF_MAX_FLOAT  1e9
  83:Lib/serial/printf.c **** #endif
  84:Lib/serial/printf.c **** 
  85:Lib/serial/printf.c **** // support for the long long types (%llu or %p)
  86:Lib/serial/printf.c **** // default: activated
  87:Lib/serial/printf.c **** #ifndef PRINTF_DISABLE_SUPPORT_LONG_LONG
  88:Lib/serial/printf.c **** #define PRINTF_SUPPORT_LONG_LONG
  89:Lib/serial/printf.c **** #endif
ARM GAS  /tmp/cc7RggvS.s 			page 3


  90:Lib/serial/printf.c **** 
  91:Lib/serial/printf.c **** // support for the ptrdiff_t type (%t)
  92:Lib/serial/printf.c **** // ptrdiff_t is normally defined in <stddef.h> as long or long long type
  93:Lib/serial/printf.c **** // default: activated
  94:Lib/serial/printf.c **** #ifndef PRINTF_DISABLE_SUPPORT_PTRDIFF_T
  95:Lib/serial/printf.c **** #define PRINTF_SUPPORT_PTRDIFF_T
