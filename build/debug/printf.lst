 178:Lib/serial/printf.c **** 
 179:Lib/serial/printf.c **** // internal test if char is a digit (0-9)
 180:Lib/serial/printf.c **** // \return true if char is a digit
 181:Lib/serial/printf.c **** static inline bool _is_digit(char ch)
 182:Lib/serial/printf.c **** {
 183:Lib/serial/printf.c ****   return (ch >= '0') && (ch <= '9');
 184:Lib/serial/printf.c **** }
