7892:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_hal_tim.c ****   *          This parameter must be a value between 0x00 and 0x0F
7893:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_hal_tim.c ****   * @retval None
7894:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_hal_tim.c ****   */
