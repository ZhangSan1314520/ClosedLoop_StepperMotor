  91:Lib/serial/serial.cpp **** 
  92:Lib/serial/serial.cpp ****     // -------------------- 6. 初始化子模块（任一失败则整体失败） ----------------
  93:Lib/serial/serial.cpp ****     // 缓冲区初始化
  94:Lib/serial/serial.cpp ****     if (!_init_buf())
  95:Lib/serial/serial.cpp ****     {
  96:Lib/serial/serial.cpp ****         _error = Serial_Error::Init_Error;
  97:Lib/serial/serial.cpp ****         return false;
  98:Lib/serial/serial.cpp ****     }
  99:Lib/serial/serial.cpp ****     // 队列初始化（FreeRTOS 消息队列，用于任务间通信）
 100:Lib/serial/serial.cpp ****     if (!_init_queue())
 101:Lib/serial/serial.cpp ****     {
 102:Lib/serial/serial.cpp ****         _error = Serial_Error::Init_Error;
 103:Lib/serial/serial.cpp ****         return false;
 104:Lib/serial/serial.cpp ****     }
 105:Lib/serial/serial.cpp ****     // 信号量初始化（二值信号量，保护发送资源）
 106:Lib/serial/serial.cpp ****     if (!_init_semaphore())
 107:Lib/serial/serial.cpp ****     {
 108:Lib/serial/serial.cpp ****         _error = Serial_Error::Init_Error;
 109:Lib/serial/serial.cpp ****         return false;
 110:Lib/serial/serial.cpp ****     }
 111:Lib/serial/serial.cpp ****     // FreeRTOS 任务初始化（接收/发送任务）
 112:Lib/serial/serial.cpp ****     if (!_init_task())
 113:Lib/serial/serial.cpp ****     {
 114:Lib/serial/serial.cpp ****         _error = Serial_Error::Init_Error;
 115:Lib/serial/serial.cpp ****         return false;
 116:Lib/serial/serial.cpp ****     }
 117:Lib/serial/serial.cpp ****     // 回调函数注册（HAL 库回调）
 118:Lib/serial/serial.cpp ****     if (!_init_callback())
 119:Lib/serial/serial.cpp ****     {
 120:Lib/serial/serial.cpp ****         _error = Serial_Error::Init_Error;
 121:Lib/serial/serial.cpp ****         return false;
 122:Lib/serial/serial.cpp ****     }
 123:Lib/serial/serial.cpp **** 
 124:Lib/serial/serial.cpp ****     // -------------------- 7. 开启串口接收 --------------------
 125:Lib/serial/serial.cpp ****     // 根据 rx_mode 选择 IT 或 DMA 模式启动接收
 126:Lib/serial/serial.cpp ****     if (!_rx_irq_start())
 127:Lib/serial/serial.cpp ****     {
 128:Lib/serial/serial.cpp ****         _error = Serial_Error::Start_Error;
 129:Lib/serial/serial.cpp ****         return false;
 130:Lib/serial/serial.cpp ****     }
 131:Lib/serial/serial.cpp **** 
 132:Lib/serial/serial.cpp ****     // -------------------- 8. 标记就绪 --------------------
 133:Lib/serial/serial.cpp ****     _ready = true;
 134:Lib/serial/serial.cpp ****     return true;
 135:Lib/serial/serial.cpp **** }
