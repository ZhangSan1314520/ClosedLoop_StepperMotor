1216:Lib/embedded-cli/embedded_cli.c ****     }
1217:Lib/embedded-cli/embedded_cli.c ****     if (history->itemsCount > 0) {
1218:Lib/embedded-cli/embedded_cli.c ****         // when history not empty, shift elements so new item is first
