  60:Lib/compute/pid/dynamic_pid.cpp **** float DynamicPID::update(float error, float nudge)
  61:Lib/compute/pid/dynamic_pid.cpp **** {
  62:Lib/compute/pid/dynamic_pid.cpp ****     _info.error = error;
  63:Lib/compute/pid/dynamic_pid.cpp ****     _info.nudge = nudge;
  64:Lib/compute/pid/dynamic_pid.cpp **** 
  65:Lib/compute/pid/dynamic_pid.cpp ****     _update_params();
  66:Lib/compute/pid/dynamic_pid.cpp **** 
  67:Lib/compute/pid/dynamic_pid.cpp ****     // Proportional term
  68:Lib/compute/pid/dynamic_pid.cpp ****     _info.P = _param.kp * error;
  69:Lib/compute/pid/dynamic_pid.cpp **** 
  70:Lib/compute/pid/dynamic_pid.cpp ****     // Integral term
  71:Lib/compute/pid/dynamic_pid.cpp ****     // _integral += error * _dt;
  72:Lib/compute/pid/dynamic_pid.cpp ****     _update_I();
  73:Lib/compute/pid/dynamic_pid.cpp **** 
  74:Lib/compute/pid/dynamic_pid.cpp ****     // Derivative term
  75:Lib/compute/pid/dynamic_pid.cpp ****     float derivative = (error - _info.prev_error) / _param.dt;
  76:Lib/compute/pid/dynamic_pid.cpp ****     _info.D = _param.kd * derivative;
  77:Lib/compute/pid/dynamic_pid.cpp **** 
  78:Lib/compute/pid/dynamic_pid.cpp ****     // Feedforward term
  79:Lib/compute/pid/dynamic_pid.cpp ****     _info.FF = _param.kff * (derivative + error);
  80:Lib/compute/pid/dynamic_pid.cpp **** 
  81:Lib/compute/pid/dynamic_pid.cpp ****     // Calculate output
  82:Lib/compute/pid/dynamic_pid.cpp ****     _info.output = _info.P + _info.I - _info.D + nudge;
  83:Lib/compute/pid/dynamic_pid.cpp **** 
  84:Lib/compute/pid/dynamic_pid.cpp ****     // Clamp output
ARM GAS  /tmp/ccIUwdHo.s 			page 10


  85:Lib/compute/pid/dynamic_pid.cpp ****     if (_info.output > _param.max)
  86:Lib/compute/pid/dynamic_pid.cpp ****         _info.output = _param.max;
  87:Lib/compute/pid/dynamic_pid.cpp ****     else if (_info.output < _param.min)
  88:Lib/compute/pid/dynamic_pid.cpp ****         _info.output = _param.min;
  89:Lib/compute/pid/dynamic_pid.cpp **** 
  90:Lib/compute/pid/dynamic_pid.cpp ****     // Save error to previous error
  91:Lib/compute/pid/dynamic_pid.cpp ****     _info.prev_error = error;
  92:Lib/compute/pid/dynamic_pid.cpp **** 
  93:Lib/compute/pid/dynamic_pid.cpp ****     return _info.output;
  94:Lib/compute/pid/dynamic_pid.cpp **** }
